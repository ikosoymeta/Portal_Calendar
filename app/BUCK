# Portal Calendar — minimal WebView android_binary.
# Based on the fbsource minimal sample fbandroid/apps/samples/simple.
# Built (uncommitted) under fbsource//fbandroid/apps/samples/portal_calendar — no diff required.
#
# Build:   buck2 build fbsource//fbandroid/apps/samples/portal_calendar:portal_calendar_arm64 --show-output
# Install: ek ar 821LCM04Z1105A24 buck install fbsource//fbandroid/apps/samples/portal_calendar:portal_calendar_arm64 -r

load("@fbsource//tools/build_defs/android:fb_android_binary.bzl", "fb_android_binary")
load("@fbsource//tools/build_defs/android:fb_core_android_library.bzl", "fb_core_android_library")
load("@fbsource//tools/build_defs:fb_native_wrapper.bzl", "fb_native")

oncall("gator")

# Bundle assets/ (index.html, app.js, app.css, *.json) into the APK at assets/*.
fb_native.android_resource(
    name = "portal_calendar-assets",
    package = "com.ikosoy.portalcalendar",
    assets = "assets",
    visibility = ["PUBLIC"],
)

fb_core_android_library(
    name = "portal_calendar-lib",
    srcs = glob(["java/**/*.java"]),
    deps = [":portal_calendar-assets"],
)

fb_android_binary(
    name = "portal_calendar_arm64",
    cpu_filters = ["arm64"],
    keystore = "//fbandroid/keystores:debug",
    manifest = "AndroidManifest.xml",
    deps = [":portal_calendar-lib"],
)
